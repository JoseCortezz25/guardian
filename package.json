{
  "name": "@ajosecortes/guardian-cli",
  "version": "1.0.0-beta.4",
  "description": "A CLI tool to enforce code quality gates before AI-assisted commits.",
  "main": "dist/cli.js",
  "bin": {
    "guardian": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "prepublishOnly": "npm run build && npm test"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "cli",
    "typescript",
    "guardian",
    "git-hooks",
    "code-quality",
    "ai",
    "automation"
  ],
  "author": "Alfonso Chavarro",
  "license": "MIT",
  "homepage": "https://github.com/JoseCortezz25/guardian#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JoseCortezz25/guardian.git"
  },
  "bugs": {
    "url": "https://github.com/JoseCortezz25/guardian/issues"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "micromatch": "^4.0.8"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/micromatch": "^4.0.9",
    "@types/node": "^22.19.17",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "typescript": "^5.7.2",
    "vitest": "^3.1.3"
  }
}
